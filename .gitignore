# Root level gitignore

# Dependencies
node_modules/
*/node_modules/
*.pnp
*.pnp.js

# Build outputs
dist/
build/
*/build/
*/.next/

# Environment variables
.env
.env.local
.env.*.local

# IDEs
.vscode/
.idea/
*.swp
*.swo
*.sublime-project
*.sublime-workspace

# OS
.DS_Store
Thumbs.db

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Testing
coverage/
.nyc_output/

# Package managers
package-lock.json
yarn.lock
pnpm-lock.yaml

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
venv/
env/
ENV/
backend/database
